# API server (apps/api). Copy to apps/api/.env and fill in real values.
# Loaded by dotenv at server boot — see apps/api/src/config/env.ts.

# Runtime --------------------------------------------------------------
# Optional. Defaults to "development". One of: development | test | production.
NODE_ENV=development
# Optional. Defaults to 4000. Persistent hosts (Render/Railway/Fly) inject PORT
# instead, which takes precedence over API_PORT at boot — no need to set it there.
API_PORT=4000
# Optional. Defaults to http://localhost:5173. Used for CORS.
WEB_ORIGIN=http://localhost:5173
# Optional. Defaults to 0 (trust no proxy — correct for local dev). Set to 1 in
# production when behind a single reverse proxy (Vercel/Render/etc.) so rate
# limiting keys on the real client IP, not the proxy's. See config/env.ts.
TRUST_PROXY=0

# Supabase -------------------------------------------------------------
# Required. From Supabase Dashboard → Project Settings → API.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
# Required. Keep secret — bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server secrets -------------------------------------------------------
# Required. 32 bytes base64. Generate with: openssl rand -base64 32
# Used for AES-256-GCM at-rest encryption of OAuth tokens and HMAC
# signatures on OAuth state nonces. Rotate carefully — re-encrypting
# existing rows is manual.
ENCRYPTION_KEY=generate-with-openssl-rand-base64-32

# Google Calendar OAuth ------------------------------------------------
# Required. Reuses the Google Cloud OAuth client also used for Supabase
# sign-in. Add http://localhost:4000/api/calendar/google/callback to the
# client's Authorized redirect URIs in Google Cloud Console.
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
# Optional. Defaults to http://localhost:4000/api/calendar/google/callback.
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/calendar/google/callback

# Transactional email (Resend) ----------------------------------------
# Optional. When unset, the email service is a no-op (booking lifecycle
# emails are logged but not sent) so local dev never reaches Resend.
# Get a key at resend.com → API Keys.
RESEND_API_KEY=re_your_resend_api_key
# Optional. Defaults to "On Deck <onboarding@resend.dev>".
# The default test sender ONLY delivers to the Resend account owner's email.
# Before soft-launch, verify a domain at resend.com/domains and set a from
# address on that domain (e.g. "On Deck <bookings@yourdomain.com>").
EMAIL_FROM=On Deck <onboarding@resend.dev>
# Optional. IANA timezone used to render session times in emails. Defaults to
# America/Chicago. A coach's availability-window timezone takes precedence.
DISPLAY_TIMEZONE=America/Chicago

# Error monitoring (Sentry) --------------------------------------------
# Optional. When unset, Sentry is never initialized (no-op). From your
# Sentry project → Settings → Client Keys (DSN).
SENTRY_DSN=
# Optional. Performance trace sample rate 0..1. Defaults to 0 (errors only).
SENTRY_TRACES_SAMPLE_RATE=0

# Video transcoding (PROTOTYPE — Phase 7 preview) ----------------------
# Optional. Off unless set to "true" or "1". Enables the admin-only endpoint
# POST /api/admin/uploads/:id/transcode, which runs ffmpeg in-process to
# convert a client upload to browser-friendly H.264 + faststart (fixes HEVC
# clips that play as a black screen). Synchronous/blocking and buffers the file
# in memory — intended for manual use on short clips, not production auto-run.
ENABLE_TRANSCODE=false
