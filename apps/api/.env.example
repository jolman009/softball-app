# API server (apps/api). Copy to apps/api/.env and fill in real values.
# Loaded by dotenv at server boot — see apps/api/src/config/env.ts.

# Runtime --------------------------------------------------------------
# Optional. Defaults to "development". One of: development | test | production.
NODE_ENV=development
# Optional. Defaults to 4000.
API_PORT=4000
# Optional. Defaults to http://localhost:5173. Used for CORS.
WEB_ORIGIN=http://localhost:5173
# Optional. Defaults to 0 (trust no proxy — correct for local dev). Set to 1 in
# production when behind a single reverse proxy (Vercel/Render/etc.) so rate
# limiting keys on the real client IP, not the proxy's. See config/env.ts.
TRUST_PROXY=0

# Supabase -------------------------------------------------------------
# Required. From Supabase Dashboard → Project Settings → API.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
# Required. Keep secret — bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server secrets -------------------------------------------------------
# Required. 32 bytes base64. Generate with: openssl rand -base64 32
# Used for AES-256-GCM at-rest encryption of OAuth tokens and HMAC
# signatures on OAuth state nonces. Rotate carefully — re-encrypting
# existing rows is manual.
ENCRYPTION_KEY=generate-with-openssl-rand-base64-32

# Google Calendar OAuth ------------------------------------------------
# Required. Reuses the Google Cloud OAuth client also used for Supabase
# sign-in. Add http://localhost:4000/api/calendar/google/callback to the
# client's Authorized redirect URIs in Google Cloud Console.
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
# Optional. Defaults to http://localhost:4000/api/calendar/google/callback.
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/calendar/google/callback
