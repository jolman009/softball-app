# Web app (apps/web). Copy to apps/web/.env and fill in real values.
# Loaded by Vite at dev/build time — see apps/web/src/lib/env.ts.
# Only VITE_-prefixed vars are exposed to client-side code.

# Optional. Branding shown in the UI shell.
VITE_APP_NAME=On Deck

# Required. From Supabase Dashboard → Project Settings → API.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Optional. Defaults to http://localhost:4000/api. Point at the deployed API in production.
VITE_API_BASE_URL=http://localhost:4000/api

# Observability (optional) ---------------------------------------------
# All optional. When a value is absent, that integration stays disabled and
# its hooks are no-ops — see lib/sentry.ts and lib/analytics.ts.

# Sentry browser DSN. From your Sentry project → Settings → Client Keys (DSN).
VITE_SENTRY_DSN=
# PostHog project API key (booking-funnel analytics). From PostHog → Project Settings.
VITE_POSTHOG_KEY=
# Optional. PostHog ingestion host. Defaults to https://us.i.posthog.com
# (use https://eu.i.posthog.com for EU projects, or your self-hosted URL).
VITE_POSTHOG_HOST=https://us.i.posthog.com
